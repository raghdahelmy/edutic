{
  "info": {
    "name": "Edutic API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/register",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Test User", "type": "text" },
                { "key": "email", "value": "test@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "role", "value": "student", "type": "text", "description": "owner | student" },
                { "key": "phone", "value": "01012345678", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/login",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "email", "value": "test@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/logout",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/profile",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/profile/update",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "New Name", "type": "text" },
                { "key": "phone", "value": "01012345678", "type": "text" },
                { "key": "password", "value": "newpassword123", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/forgot-password",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "email", "value": "test@example.com", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/reset-password",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "email", "value": "test@example.com", "type": "text" },
                { "key": "otp", "value": "123456", "type": "text" },
                { "key": "password", "value": "newpassword123", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users?role=student&status=approved&search=test&per_page=10",
              "query": [
                { "key": "role", "value": "student" },
                { "key": "status", "value": "approved" },
                { "key": "search", "value": "test" },
                { "key": "per_page", "value": "10" }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Update User Status (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/users/1/status",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "status", "value": "approved", "type": "text", "description": "pending | approved | rejected" }
              ]
            }
          }
        },
        {
          "name": "Assign Role (Owner)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users/1/role",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "role", "value": "admin", "type": "text", "description": "admin | student" }
              ]
            }
          }
        },
        {
          "name": "Create User (Owner)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users/create",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "New User", "type": "text" },
                { "key": "email", "value": "newuser@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "role", "value": "admin", "type": "text", "description": "admin | student" },
                { "key": "phone", "value": "01012345678", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            }
          }
        }
      ]
